function handleInvFull(action,price){
  if(action==='sell'){player.money+=price;trackQuestProgress('earn',price);toast(`Quick sold for ₹${fmt(price)}`,'gold');updateUI();}
  else toast('Item dropped.','red');
  pendingCaughtItem=null; closeModal();
}

