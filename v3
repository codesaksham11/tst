// ═══════════════════════════════════════════
//  STATE
// ═══════════════════════════════════════════
let player = {
  money:500, gems:0, exp:0, level:1, maxInv:100, shopSlots:6,
  inv:[], rodLevel:1, lastShopTime:Date.now(), shopInventory:[],
  stats:{ totalCaught:0, raresCaught:0, heroicCaught:0, bjWins:0, bj21s:0, peakMoney:500, sellCount:0, earnedToday:0 },
  achievements:[],
  quests:[], questDate:''
};

let fishingDeck=[], fishingState='idle';
let fishingTimeout, biteTimeout;
let shopTimeRemaining=300;
let pendingCaughtItem=null;

// BJ state
let bjDeck=[], bjDealer={cards:[]}, bjHands=[], currentHandIndex=0;
let bjMinBet=10, bjMaxBet=1000, bjState='betting';
let bjInsuranceTaken=false;

// ═══════════════════════════════════════════
//  LOADER
// ═══════════════════════════════════════════
const LOAD_STEPS = [
  'Casting nets...','Checking tides...','Polishing cards...',
  'Counting gold...','Waking fish...','Opening the casino...'
];

function runLoader() {
  const bar = document.getElementById('loader-bar');
  const step = document.getElementById('loader-step');
  let pct = 0, si = 0;
  const iv = setInterval(() => {
    pct += rand(10,20);
    if(pct>100) pct=100;
    bar.style.width = pct+'%';
    step.innerText = LOAD_STEPS[si++ % LOAD_STEPS.length];
    if(pct>=100) {
      clearInterval(iv);
      setTimeout(() => {
        document.getElementById('loader').style.transition='opacity 0.6s';
        document.getElementById('loader').style.opacity='0';
        setTimeout(()=>document.getElementById('loader').style.display='none',600);
      }, 400);
    }
  }, 350);
}

// ═══════════════════════════════════════════
//  INIT
// ═══════════════════════════════════════════
window.onload = () => {
  runLoader();
  loadGame();
  buildDeck();
  let secondsPassed = Math.floor((Date.now()-player.lastShopTime)/1000);
  if(secondsPassed>=300 || player.shopInventory.length===0) generateShop();
  else shopTimeRemaining=300-secondsPassed;
  setInterval(updateShopTimer,1000);
  refreshDailyQuests();
  updateUI();
  updateBjLimits();
  setInterval(saveGame, 15000); // auto-save every 15s
};

function saveGame() {
  player.lastShopTime = Date.now()-((300-shopTimeRemaining)*1000);
  localStorage.setItem('fc_save_v2', JSON.stringify(player));
}

function loadGame() {
  let saved = localStorage.getItem('fc_save_v2');
  if(saved) {
    try {
      let parsed = JSON.parse(saved);
      // Deep merge stats & achievements
      player = {...player,...parsed};
      if(!player.stats) player.stats={totalCaught:0,raresCaught:0,heroicCaught:0,bjWins:0,bj21s:0,peakMoney:500,sellCount:0,earnedToday:0};
      if(!player.achievements) player.achievements=[];
      if(!player.quests) player.quests=[];
      if(!player.questDate) player.questDate='';
    } catch(e) { console.error('Save corrupted'); }
  }
}

function resetSave() {
  showModal(`<h3>Reset Progress?</h3><p style="margin-top:8px">This cannot be undone. All progress will be lost forever.</p><div class="modal-buttons"><button onclick="closeModal()">Cancel</button><button class="btn-danger" onclick="localStorage.removeItem('fc_save_v2');location.reload()">Reset Everything</button></div>`);
}

// ═══════════════════════════════════════════
//  UI
// ═══════════════════════════════════════════
function toggleMenu() {
  document.getElementById('sidebar').classList.toggle('open');
  document.getElementById('overlay-bg').style.display =
    document.getElementById('sidebar').classList.contains('open') ? 'block' : 'none';
}

function switchView(v) {
  document.querySelectorAll('.view').forEach(el=>el.classList.remove('active'));
  document.getElementById(`view-${v}`).classList.add('active');
  toggleMenu();
  if(v==='inventory') renderInventory();
  if(v==='shop') renderShop();
  if(v==='achievements') renderAchievements();
  if(v==='quests') renderQuests();
}

function updateUI() {
  document.getElementById('ui-money').innerText=`💰 ₹${fmt(player.money)}`;
  document.getElementById('ui-gems').innerText=`💎 ${player.gems}`;
  document.getElementById('ui-rod').innerText=`Rod ${'I'.repeat(player.rodLevel)}`;
  document.getElementById('ui-inv-count').innerText=`🎒 ${player.inv.length}/${player.maxInv}`;

  player.level = Math.floor(Math.sqrt(player.exp/100))+1;
  let nextExp = Math.pow(player.level,2)*100;
  let curLvlExp = Math.pow(player.level-1,2)*100;
  let pct = ((player.exp-curLvlExp)/(nextExp-curLvlExp))*100;
  document.getElementById('ui-level').innerText=`Lvl ${player.level}`;
  document.getElementById('xp-bar-fill').style.width=Math.min(100,pct)+'%';

  if(player.money > player.stats.peakMoney) player.stats.peakMoney=player.money;
  checkAchievements();
}

function fmt(n) {
  if(n>=1000000) return (n/1000000).toFixed(2)+'M';
  if(n>=1000) return (n/1000).toFixed(1)+'k';
  return n.toLocaleString();
}

function toast(msg, type='') {
  let el=document.createElement('div');
  el.className=`toast ${type?'toast-'+type:''}`;
  el.innerHTML=msg;
  document.getElementById('toast-container').appendChild(el);
  setTimeout(()=>el.remove(),3100);
}

// ═══════════════════════════════════════════
//  INVENTORY
// ═══════════════════════════════════════════
function addItem(id) {
  const d = ITEMS[id];
  if(id==='gem') { player.gems++; updateUI(); saveGame(); return true; }
  if(d.stackable) {
    let ex = player.inv.find(i=>i.id===id);
    if(ex) { ex.qty++; updateUI(); saveGame(); return true; }
  }
  if(player.inv.length>=player.maxInv) { pendingCaughtItem=id; showFullInvModal(id); return false; }
  player.inv.push({id,qty:1,uid:Math.random().toString(36).substr(2,9)});
  updateUI(); saveGame(); return true;
}

function removeItem(id,qty=1,uid=null) {
  if(uid) { let i=player.inv.findIndex(x=>x.uid===uid); if(i>-1) player.inv.splice(i,1); }
  else {
    let ex=player.inv.find(x=>x.id===id);
    if(ex){ ex.qty-=qty; if(ex.qty<=0) player.inv=player.inv.filter(x=>x!==ex); }
  }
  updateUI();
  if(document.getElementById('view-inventory').classList.contains('active')) renderInventory();
}

function hasItem(id){ return player.inv.some(i=>i.id===id); }
function getInvQty(id){ let c=0; player.inv.forEach(i=>{if(i.id===id)c+=i.qty;}); return c; }

function equipRod(id,uid,lvl) {
  if(player.rodLevel>=lvl){ toast('You have a better rod equipped!','red'); return; }
  player.rodLevel=lvl; removeItem(id,1,uid); buildDeck();
  toast(`Equipped ${ITEMS[id].name}! 🎣`,'gold'); updateUI();
}

function upgradeInvCash(){
  if(player.money>=1000000){player.money-=1000000;player.maxInv+=10;toast('+10 Inventory Slots!','green');updateUI();}
  else toast('Need ₹1,000,000!','red');
}
function upgradeInvGems(){
  if(player.gems>=3){player.gems-=3;player.maxInv+=10;toast('+10 Inventory Slots!','green');updateUI();}
  else toast('Need 3 💎!','red');
}
function cashGem(){
  if(player.gems>=1){player.gems-=1;player.money+=250000;toast('Cashed 1 💎 → ₹250,000','gold');updateUI();}
  else toast('No gems!','red');
}
function upgradeShopGems(){
  if(player.gems>=10){player.gems-=10;player.shopSlots++;toast('+1 Shop Slot!','gold');generateShop();updateUI();}
  else toast('Need 10 💎!','red');
}

function quickSellFromInv(id,uid,qty) {
  let p=Math.floor(ITEMS[id].basePrice*0.7)*qty;
  player.money+=p;
  player.stats.sellCount+=qty;
  trackQuestProgress('sell',qty);
  trackQuestProgress('earn',p);
  removeItem(id,qty,uid);
  toast(`Sold for ₹${fmt(p)}`,'gold');
  checkAchievements();
}

function renderInventory() {
  const grid=document.getElementById('inv-grid');
  grid.innerHTML='';
  if(player.inv.length===0){grid.innerHTML=`<p style="color:var(--text2);font-family:'IM Fell English',serif;font-style:italic;">Your inventory is empty. Go catch something!</p>`;return;}
  player.inv.forEach(i=>{
    let d=ITEMS[i.id];
    let div=document.createElement('div');
    div.className=`inv-item rarity-${d.rarity}`;
    let actionHtml='';
    if(d.type==='rod'){
      let rLvl=i.id==='rod_2'?2:3;
      if(player.rodLevel<rLvl) actionHtml+=`<button class="btn-gold" onclick="equipRod('${i.id}','${i.uid}',${rLvl})" style="margin-bottom:5px">Equip</button>`;
    }
    div.innerHTML=`
      <div>
        <div class="emoji">${d.emoji}</div>
        ${d.stackable?`<div class="qty">×${i.qty}</div>`:''}
        <div class="item-name">${d.name}</div>
        <div class="item-rarity rarity-label-${d.rarity}">${d.rarity.charAt(0).toUpperCase()+d.rarity.slice(1)}</div>
        ${d.desc?`<div style="font-size:10px;color:var(--teal);font-family:'IM Fell English',serif;font-style:italic;margin-bottom:4px">${d.desc}</div>`:''}
      </div>
      <div>${actionHtml}<button onclick="quickSellFromInv('${i.id}','${i.uid}',${i.qty})">Quick Sell (−30%)</button></div>`;
    grid.appendChild(div);
  });
}

