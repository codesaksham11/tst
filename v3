<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Fisherman's Casino</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700&family=Cinzel:wght@400;600&family=IM+Fell+English:ital@0;1&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0a0a0f;
  --deep: #050508;
  --panel: #12121a;
  --panel2: #1a1a26;
  --border: #2a2a40;
  --gold: #c8a84b;
  --gold2: #f0d080;
  --gold3: #8a6a20;
  --teal: #2abfbf;
  --teal2: #1a8f8f;
  --red: #e03030;
  --green: #28a060;
  --green2: #1a6a40;
  --text: #d4cfc8;
  --text2: #8a8070;
  --common: #9e9e9e;
  --uncommon: #4caf50;
  --rare: #2196f3;
  --epic: #9c27b0;
  --legendary: #ff9800;
  --heroic: #e91e63;
  --shadow: 0 8px 32px rgba(0,0,0,0.6);
}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:'Cinzel',serif;overflow-x:hidden;min-height:100vh;}

/* ── LOADING SCREEN ── */
#loader{position:fixed;inset:0;background:var(--deep);z-index:9999;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:24px;}
#loader h1{font-family:'Cinzel Decorative',serif;font-size:clamp(22px,5vw,42px);color:var(--gold);text-shadow:0 0 30px var(--gold3);letter-spacing:3px;animation:pulse 2s ease-in-out infinite;}
.loader-fish{font-size:50px;animation:swim 1.5s ease-in-out infinite;}
.loader-bar-wrap{width:min(340px,80vw);height:6px;background:#1a1a2a;border-radius:99px;overflow:hidden;border:1px solid var(--border);}
.loader-bar{height:100%;width:0%;background:linear-gradient(90deg,var(--gold3),var(--gold),var(--gold2));border-radius:99px;transition:width 0.3s ease;}
.loader-step{color:var(--text2);font-family:'IM Fell English',serif;font-size:14px;font-style:italic;min-height:20px;transition:0.3s;}
@keyframes pulse{0%,100%{opacity:0.8}50%{opacity:1;text-shadow:0 0 50px var(--gold);}}
@keyframes swim{0%,100%{transform:translateY(0) rotate(-5deg)}50%{transform:translateY(-12px) rotate(5deg)}}

/* ── NAVBAR ── */
#navbar{background:linear-gradient(180deg,#0d0d18 0%,#090912 100%);padding:10px 18px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--gold3);position:sticky;top:0;z-index:100;gap:10px;flex-wrap:wrap;}
.nav-brand{font-family:'Cinzel Decorative',serif;font-size:clamp(13px,3vw,20px);color:var(--gold);letter-spacing:2px;text-shadow:0 0 20px var(--gold3);white-space:nowrap;}
.hamburger{font-size:22px;cursor:pointer;color:var(--gold);padding:4px 8px;border-radius:4px;transition:0.2s;user-select:none;}
.hamburger:hover{background:rgba(200,168,75,0.1);}
.stats{display:flex;flex-wrap:wrap;gap:8px;align-items:center;}
.stat-badge{background:var(--panel2);border:1px solid var(--border);padding:5px 10px;border-radius:6px;font-size:clamp(11px,2.2vw,14px);font-family:'IM Fell English',serif;color:var(--text);white-space:nowrap;}
.stat-badge.gold-badge{border-color:var(--gold3);color:var(--gold);}

/* ── SIDEBAR ── */
#sidebar{position:fixed;top:0;left:-270px;width:270px;height:100%;background:linear-gradient(180deg,#0d0d18,#090912);border-right:1px solid var(--gold3);transition:0.3s cubic-bezier(.4,0,.2,1);z-index:1000;padding-top:60px;box-shadow:5px 0 30px rgba(0,0,0,0.8);}
#sidebar.open{left:0;}
#sidebar a{display:flex;align-items:center;gap:12px;padding:14px 22px;color:var(--text);text-decoration:none;font-size:16px;border-bottom:1px solid #1a1a2a;cursor:pointer;transition:0.2s;font-family:'Cinzel',serif;letter-spacing:1px;}
#sidebar a:hover{background:rgba(200,168,75,0.07);color:var(--gold);padding-left:30px;}
#sidebar a .nav-icon{font-size:20px;width:28px;text-align:center;}
.close-btn{position:absolute;top:12px;right:18px;font-size:28px;cursor:pointer;color:var(--text2);transition:0.2s;}
.close-btn:hover{color:var(--gold);}
.sidebar-footer{padding:18px 22px;position:absolute;bottom:0;width:100%;border-top:1px solid #1a1a2a;}
#overlay-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:999;}

/* ── MAIN VIEWS ── */
.view{display:none;padding:20px;max-width:1000px;margin:auto;animation:fadeIn 0.3s ease;}
.view.active{display:block;}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.view-title{font-family:'Cinzel Decorative',serif;font-size:clamp(16px,4vw,24px);color:var(--gold);margin-bottom:18px;padding-bottom:12px;border-bottom:1px solid var(--gold3);display:flex;align-items:center;gap:10px;letter-spacing:2px;}

/* ── BUTTONS ── */
button{background:linear-gradient(135deg,var(--green2),var(--green));color:#fff;border:1px solid rgba(255,255,255,0.1);padding:9px 18px;cursor:pointer;border-radius:6px;font-weight:600;transition:0.2s;font-family:'Cinzel',serif;font-size:13px;letter-spacing:0.5px;}
button:hover{filter:brightness(1.15);transform:translateY(-1px);}
button:active{transform:translateY(0);}
button:disabled{background:linear-gradient(135deg,#222,#333);color:#555;cursor:not-allowed;transform:none;filter:none;}
button.btn-gold{background:linear-gradient(135deg,var(--gold3),var(--gold));}
button.btn-danger{background:linear-gradient(135deg,#7a1010,var(--red));}
button.btn-teal{background:linear-gradient(135deg,var(--teal2),var(--teal));}
button.btn-lg{font-size:16px;padding:12px 28px;border-radius:30px;letter-spacing:1px;}
select,input{padding:9px 12px;border-radius:6px;border:1px solid var(--border);background:var(--panel2);color:var(--text);font-family:'Cinzel',serif;font-size:13px;width:100%;max-width:220px;}
select:focus,input:focus{outline:none;border-color:var(--gold3);}

/* ── RARITY ── */
.rarity-common{border:1px solid var(--common)!important;box-shadow:0 0 6px rgba(158,158,158,0.2);}
.rarity-uncommon{border:1px solid var(--uncommon)!important;box-shadow:0 0 6px rgba(76,175,80,0.25);}
.rarity-rare{border:1px solid var(--rare)!important;box-shadow:0 0 8px rgba(33,150,243,0.3);}
.rarity-epic{border:1px solid var(--epic)!important;box-shadow:0 0 10px rgba(156,39,176,0.35);}
.rarity-legendary{border:1px solid var(--legendary)!important;box-shadow:0 0 12px rgba(255,152,0,0.4);}
.rarity-heroic{border:1px solid var(--heroic)!important;box-shadow:0 0 16px rgba(233,30,99,0.5);animation:heroicPulse 2s ease-in-out infinite;}
@keyframes heroicPulse{0%,100%{box-shadow:0 0 16px rgba(233,30,99,0.5)}50%{box-shadow:0 0 28px rgba(233,30,99,0.8)}}

/* ── FISHING ── */
#pond{width:100%;max-width:620px;height:340px;border-radius:16px;position:relative;overflow:hidden;margin:0 auto 18px;border:2px solid #1a4060;cursor:crosshair;background:radial-gradient(ellipse at 30% 40%,#0e5a8a 0%,#073a6a 50%,#031d3a 100%);}
.pond-ripple{position:absolute;width:60px;height:20px;border-radius:50%;border:1px solid rgba(255,255,255,0.12);top:50%;left:50%;transform:translate(-50%,-50%);animation:ripple 3s ease-out infinite;}
.pond-ripple:nth-child(2){animation-delay:1s;width:100px;height:32px;}
.pond-ripple:nth-child(3){animation-delay:2s;width:140px;height:46px;}
@keyframes ripple{0%{opacity:0.4;transform:translate(-50%,-50%) scale(1)}100%{opacity:0;transform:translate(-50%,-50%) scale(2)}}
#bobber{width:18px;height:18px;background:radial-gradient(circle at 35% 35%,#ff6060,#c00);border-radius:50%;position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);border:2px solid #fff;box-shadow:0 2px 8px rgba(0,0,0,0.5);transition:top 0.1s,left 0.1s;}
#bobber::before{content:'';position:absolute;bottom:100%;left:50%;transform:translateX(-50%);width:1px;height:20px;background:rgba(255,255,255,0.4);}
#bobber.bobbing{animation:bob 0.8s ease-in-out infinite;}
#bobber.splash{animation:splashAnim 0.3s ease-out;background:radial-gradient(circle at 35% 35%,#ffff60,#ffa000)!important;box-shadow:0 0 20px #ffd700,0 0 40px rgba(255,165,0,0.5)!important;}
@keyframes bob{0%,100%{margin-top:0}50%{margin-top:5px}}
@keyframes splashAnim{0%{transform:translate(-50%,-50%) scale(1)}50%{transform:translate(-50%,-50%) scale(2.5)}100%{transform:translate(-50%,-50%) scale(1)}}
.trail-particle{position:absolute;width:8px;height:8px;background:rgba(100,200,255,0.8);border-radius:50%;box-shadow:0 0 8px rgba(100,200,255,0.9);pointer-events:none;}
#fish-log{text-align:center;margin-top:10px;font-size:18px;font-family:'IM Fell English',serif;font-style:italic;min-height:28px;color:var(--gold2);text-shadow:0 0 10px rgba(240,208,128,0.4);}
#fishing-controls{text-align:center;}
.pull-flash{animation:flashPull 0.4s ease-in-out infinite;}
@keyframes flashPull{0%,100%{filter:brightness(1)}50%{filter:brightness(1.5) drop-shadow(0 0 12px #ffd700)}}

/* Fish particle drop */
@keyframes fishCatch{0%{opacity:1;transform:translate(-50%,-50%) scale(1)}100%{opacity:0;transform:translate(-50%,-200%) scale(0)}}

/* ── INVENTORY ── */
.inv-actions{margin-bottom:18px;display:flex;gap:10px;flex-wrap:wrap;background:var(--panel);padding:14px;border-radius:10px;border:1px solid var(--border);}
.inv-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:12px;}
.inv-item{background:var(--panel);padding:12px;text-align:center;border-radius:8px;position:relative;display:flex;flex-direction:column;justify-content:space-between;transition:transform 0.2s;}
.inv-item:hover{transform:translateY(-2px);}
.inv-item .emoji{font-size:38px;margin-bottom:6px;}
.inv-item .qty{position:absolute;top:6px;right:6px;background:rgba(0,0,0,0.8);border:1px solid var(--border);padding:2px 7px;border-radius:10px;font-size:11px;font-weight:bold;color:var(--gold);}
.inv-item .item-name{font-size:12px;font-weight:600;margin-bottom:3px;color:var(--text);}
.inv-item .item-rarity{font-size:10px;font-family:'IM Fell English',serif;font-style:italic;margin-bottom:6px;}
.rarity-label-common{color:var(--common);}
.rarity-label-uncommon{color:var(--uncommon);}
.rarity-label-rare{color:var(--rare);}
.rarity-label-epic{color:var(--epic);}
.rarity-label-legendary{color:var(--legendary);}
.rarity-label-heroic{color:var(--heroic);}
.inv-item button{margin-top:4px;width:100%;font-size:11px;padding:6px;}

/* ── SHOP ── */
#shop-timer-wrap{background:var(--panel);border:1px solid var(--gold3);border-radius:8px;padding:10px 18px;display:inline-flex;align-items:center;gap:10px;}
#shop-timer{color:var(--gold);font-size:22px;font-family:'Cinzel Decorative',serif;letter-spacing:2px;}
.shop-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(210px,1fr));gap:14px;margin-top:18px;}
.shop-slot{background:var(--panel);padding:16px;border-radius:10px;text-align:center;display:flex;flex-direction:column;justify-content:space-between;transition:transform 0.2s;}
.shop-slot:hover{transform:translateY(-2px);}
.shop-slot .shop-emoji{font-size:36px;margin-bottom:8px;}
.shop-slot .shop-name{font-size:14px;font-weight:600;margin-bottom:4px;}
.shop-slot .shop-price{font-size:17px;font-family:'IM Fell English',serif;margin:8px 0;color:var(--gold);}
.shop-slot .shop-limit{font-size:11px;color:var(--text2);margin-bottom:10px;}
.shop-slot-actions{display:flex;gap:6px;justify-content:center;flex-wrap:wrap;}
.shop-tag{display:inline-block;font-size:10px;padding:2px 8px;border-radius:99px;margin-bottom:6px;font-family:'IM Fell English',serif;font-style:italic;}
.shop-tag.buying{background:rgba(40,160,96,0.2);color:var(--green);border:1px solid var(--green2);}
.shop-tag.selling{background:rgba(200,168,75,0.15);color:var(--gold);border:1px solid var(--gold3);}

/* ── BLACKJACK ── */
#bj-table{background:radial-gradient(ellipse at center,#0a4a20 0%,#063015 60%,#031a0c 100%);border-radius:20px;padding:22px;min-height:360px;border:4px solid #2a1800;box-shadow:inset 0 0 60px rgba(0,0,0,0.6),0 0 30px rgba(0,0,0,0.5);position:relative;text-align:center;margin-top:14px;}
#bj-table::before{content:'FISHERMAN\'S CASINO';position:absolute;top:14px;left:50%;transform:translateX(-50%);color:rgba(200,168,75,0.15);font-family:'Cinzel Decorative',serif;font-size:12px;letter-spacing:4px;white-space:nowrap;}
.cards-area{min-height:100px;display:flex;justify-content:center;flex-wrap:wrap;gap:6px;padding:6px;}
.card{width:58px;height:86px;background:#fff;color:#111;border-radius:6px;font-size:18px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-direction:column;box-shadow:2px 4px 10px rgba(0,0,0,0.6),inset 0 1px 0 rgba(255,255,255,0.8);border:1px solid #ddd;margin:3px;position:relative;transition:transform 0.2s;}
.card:hover{transform:translateY(-4px);}
.card .card-suit{font-size:12px;opacity:0.7;}
.card.red{color:#c00;}
.card.hidden{background:#b71c1c;background-image:repeating-linear-gradient(45deg,transparent,transparent 8px,rgba(0,0,0,0.15) 8px,rgba(0,0,0,0.15) 16px);color:transparent;}
.card.hidden .card-suit{display:none;}
.card.deal-in{animation:dealCard 0.3s ease-out;}
@keyframes dealCard{from{transform:translateY(-30px) scale(0.8);opacity:0}to{transform:translateY(0) scale(1);opacity:1}}
.hand-score{background:rgba(0,0,0,0.7);border:1px solid rgba(200,168,75,0.3);padding:5px 12px;border-radius:20px;display:inline-block;margin-bottom:8px;font-size:13px;color:var(--gold);font-family:'IM Fell English',serif;}
.split-hands{display:flex;justify-content:center;gap:20px;flex-wrap:wrap;}
.active-hand{outline:2px solid var(--gold);outline-offset:6px;border-radius:6px;}
.bj-bet-area{display:flex;flex-wrap:wrap;gap:10px;align-items:center;justify-content:center;background:var(--panel);padding:16px;border-radius:12px;border:1px solid var(--border);margin-bottom:14px;}
#bj-controls{background:var(--panel);padding:14px;border-radius:10px;border:1px solid var(--border);display:none;justify-content:center;gap:10px;flex-wrap:wrap;}
#bj-msg{font-size:16px;font-family:'IM Fell English',serif;font-style:italic;text-align:center;margin:10px 0;min-height:24px;color:var(--gold2);}

/* BJ 21 Bonus Banner */
#bj-21-banner{position:absolute;inset:0;display:none;align-items:center;justify-content:center;z-index:10;pointer-events:none;border-radius:18px;}
#bj-21-banner.show{display:flex;animation:bannerIn 0.5s cubic-bezier(.175,.885,.32,1.275);}
@keyframes bannerIn{from{transform:scale(0.5);opacity:0}to{transform:scale(1);opacity:1}}
.banner-inner{background:linear-gradient(135deg,#7a4800,var(--gold),#7a4800);padding:18px 36px;border-radius:16px;font-family:'Cinzel Decorative',serif;font-size:clamp(20px,5vw,36px);color:#fff;text-shadow:0 2px 4px rgba(0,0,0,0.5);box-shadow:0 0 60px rgba(200,168,75,0.8),inset 0 1px 0 rgba(255,255,255,0.3);text-align:center;}

/* ── ACHIEVEMENTS ── */
.ach-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px;}
.ach-card{background:var(--panel);border:1px solid var(--border);padding:14px;border-radius:10px;display:flex;gap:12px;align-items:flex-start;transition:0.2s;}
.ach-card.earned{border-color:var(--gold3);background:linear-gradient(135deg,#12120a,#1a1800);}
.ach-card.earned .ach-name{color:var(--gold);}
.ach-icon{font-size:30px;min-width:36px;text-align:center;}
.ach-name{font-size:13px;font-weight:600;margin-bottom:3px;}
.ach-desc{font-size:11px;color:var(--text2);font-family:'IM Fell English',serif;font-style:italic;}
.ach-reward{font-size:11px;color:var(--green);margin-top:4px;}

/* ── LEADERBOARD ── */
.lb-row{display:flex;align-items:center;gap:14px;padding:12px 16px;background:var(--panel);border-radius:8px;border:1px solid var(--border);margin-bottom:8px;}
.lb-rank{font-size:20px;min-width:32px;text-align:center;}
.lb-name{flex:1;font-size:14px;}
.lb-score{color:var(--gold);font-family:'IM Fell English',serif;font-size:15px;}

/* ── DAILY QUESTS ── */
.quest-card{background:var(--panel);border:1px solid var(--border);border-radius:10px;padding:14px 16px;margin-bottom:10px;display:flex;align-items:center;gap:14px;flex-wrap:wrap;}
.quest-card.done{border-color:var(--gold3);opacity:0.7;}
.quest-info{flex:1;min-width:160px;}
.quest-name{font-size:14px;font-weight:600;margin-bottom:3px;}
.quest-desc{font-size:12px;color:var(--text2);font-family:'IM Fell English',serif;font-style:italic;}
.quest-prog{height:5px;background:#1a1a2a;border-radius:99px;margin-top:6px;overflow:hidden;}
.quest-prog-fill{height:100%;background:linear-gradient(90deg,var(--gold3),var(--gold));border-radius:99px;transition:width 0.5s ease;}
.quest-reward{font-size:12px;color:var(--green);white-space:nowrap;}

/* ── TOAST NOTIFICATIONS ── */
#toast-container{position:fixed;top:70px;right:16px;z-index:5000;display:flex;flex-direction:column;gap:8px;max-width:280px;}
.toast{background:var(--panel2);border:1px solid var(--border);border-radius:8px;padding:12px 16px;font-size:13px;font-family:'IM Fell English',serif;font-style:italic;color:var(--text);box-shadow:var(--shadow);animation:toastIn 0.3s ease,toastOut 0.3s ease 2.7s forwards;display:flex;align-items:center;gap:10px;}
.toast.toast-gold{border-color:var(--gold3);color:var(--gold);}
.toast.toast-green{border-color:var(--green2);color:#6ddc9a;}
.toast.toast-red{border-color:#7a1010;color:#ff8080;}
.toast.toast-epic{border-color:var(--epic);color:#d580ff;}
.toast.toast-legendary{border-color:var(--legendary);color:var(--legendary);}
.toast.toast-heroic{border-color:var(--heroic);color:#ff80a0;}
@keyframes toastIn{from{opacity:0;transform:translateX(30px)}to{opacity:1;transform:translateX(0)}}
@keyframes toastOut{from{opacity:1}to{opacity:0;transform:translateX(30px)}}

/* ── MODAL ── */
#modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:2000;display:none;align-items:center;justify-content:center;padding:20px;backdrop-filter:blur(4px);}
#modal-overlay.show{display:flex;}
.modal{background:var(--panel);border:1px solid var(--gold3);padding:28px;border-radius:14px;width:100%;max-width:420px;text-align:center;box-shadow:0 0 60px rgba(200,168,75,0.15);}
.modal h3{font-family:'Cinzel Decorative',serif;color:var(--gold);margin-bottom:14px;font-size:18px;}
.modal p{font-family:'IM Fell English',serif;font-style:italic;color:var(--text);line-height:1.6;}
.modal-buttons{display:flex;justify-content:center;gap:10px;margin-top:20px;flex-wrap:wrap;}

/* ── XP BAR FULL WIDTH ── */
.xp-bar-wrap{height:3px;background:#1a1a2a;position:fixed;bottom:0;left:0;right:0;z-index:99;}
.xp-bar-fill{height:100%;background:linear-gradient(90deg,var(--gold3),var(--gold2));transition:width 0.6s ease;}

/* ── RESPONSIVE ── */
@media(max-width:600px){
  #navbar{flex-direction:column;align-items:flex-start;}
  .stats{gap:6px;}
  #pond{height:270px;}
  .inv-grid{grid-template-columns:repeat(auto-fill,minmax(105px,1fr));}
  .card{width:48px;height:72px;font-size:14px;}
}
</style>
</head>
<body>

<!-- ── LOADING SCREEN ── -->
<div id="loader">
  <div class="loader-fish">🎣</div>
  <h1>Fisherman's Casino</h1>
  <div class="loader-bar-wrap"><div class="loader-bar" id="loader-bar"></div></div>
  <div class="loader-step" id="loader-step">Casting nets...</div>
</div>

<!-- ── TOAST ── -->
<div id="toast-container"></div>

<!-- ── XP BAR ── -->
<div class="xp-bar-wrap"><div class="xp-bar-fill" id="xp-bar-fill" style="width:0%"></div></div>

<!-- ── NAVBAR ── -->
<div id="navbar">
  <div style="display:flex;align-items:center;gap:12px;">
    <div class="hamburger" onclick="toggleMenu()">☰</div>
    <div class="nav-brand">🎣 Fisherman's Casino</div>
  </div>
  <div class="stats">
    <span class="stat-badge gold-badge" id="ui-money">💰 ₹500</span>
    <span class="stat-badge gold-badge" id="ui-gems">💎 0</span>
    <span class="stat-badge" id="ui-level">Lvl 1</span>
    <span class="stat-badge" id="ui-rod">Rod I</span>
    <span class="stat-badge" id="ui-inv-count">🎒 0/100</span>
  </div>
</div>

<!-- ── SIDEBAR ── -->
<div id="overlay-bg" onclick="toggleMenu()"></div>
<div id="sidebar">
  <div class="close-btn" onclick="toggleMenu()">×</div>
  <a onclick="switchView('fishing')"><span class="nav-icon">🎣</span>Fishing Pond</a>
